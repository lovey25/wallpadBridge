#ifndef CREDENTIALS_H
#define CREDENTIALS_H

// ===== WiFi 설정 =====
// WiFi SSID/비밀번호는 config.json에서 로드됨
// 초기 연결 실패 시 AP 모드 활성화:
//  - SSID: Wallpad_Setup
//  - 비밀번호: 12345678
#define WIFI_SSID "YourSSID"
#define WIFI_PASS "YourPassword"

// ===== MQTT 설정 =====
// Home Assistant 또는 다른 MQTT 브로커 정보
// 변경 후 재컴파일 필요
#define MQTT_SERVER "192.168.1.100"     // MQTT 서버 IP
#define MQTT_PORT 1883                   // MQTT 포트 (기본값: 1883)
#define MQTT_USER "username"             // MQTT 사용자명
#define MQTT_PASS "password"             // MQTT 비밀번호

// ===== OTA 설정 (선택) =====
// OTA_PASSWORD를 비워두면 비밀번호 없이 OTA 업로드가 가능합니다.
// 보안을 위해 실제 사용 시 비밀번호를 설정하세요.
#define OTA_HOSTNAME "wallpad-bridge"
#define OTA_PASSWORD ""

#endif
